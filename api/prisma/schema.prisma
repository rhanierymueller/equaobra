generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── User (profissional e/ou contratante) ─────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           String   // primary: 'profissional' | 'contratante'
  roles          String   // JSON array: ["profissional","contratante"]
  profession     String?  // primary profession (legacy compat)
  professions    String?  // JSON array of professions
  hourlyRate     Float?
  showHourlyRate Boolean  @default(true)
  avatarUrl      String?
  bio            String?
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  available      Boolean  @default(true)
  phone          String?
  tags           String?  // JSON array
  companyName    String?
  cnpj           String?
  website        String?
  instagram      String?
  facebook       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Professional address
  addrCep          String?
  addrStreet       String?
  addrNeighborhood String?
  addrCity         String?
  addrState        String?
  addrNumber       String?
  addrLat          Float?
  addrLng          Float?

  // Company address (contratante)
  compAddrCep          String?
  compAddrStreet       String?
  compAddrNeighborhood String?
  compAddrCity         String?
  compAddrState        String?
  compAddrNumber       String?

  // Relations
  ownedTeams        Team[]         @relation("TeamOwner")
  opportunities     Opportunity[]
  interests         Interest[]     @relation("ProfessionalInterests")
  toNotifications   Notification[] @relation("ToMember")
  fromNotifications Notification[] @relation("FromMember")
  messages          Message[]
}

// ── Team ─────────────────────────────────────────────────────────────────────

model Team {
  id             String   @id @default(cuid())
  name           String
  obraLocation   String
  estimatedDays  Int
  observations   String   @default("")
  scheduledStart String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner         User           @relation("TeamOwner", fields: [ownerId], references: [id])
  members       TeamMember[]
  workLogs      WorkLog[]
  notifications Notification[]
}

model TeamMember {
  id             String  @id @default(cuid())
  teamId         String
  professionalId String
  name           String
  profession     String
  phone          String
  avatarUrl      String?
  avatarInitials String
  hourlyRate     Float?
  isLeader       Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ── WorkLog ───────────────────────────────────────────────────────────────────

model WorkLog {
  id          String   @id @default(cuid())
  teamId      String
  memberId    String
  memberName  String
  date        String   // YYYY-MM-DD
  hours       Float
  description String?
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ── Opportunity (vaga/obra publicada pelo contratante) ────────────────────────

model Opportunity {
  id                    String   @id @default(cuid())
  contractorId          String
  contractorName        String
  companyName           String?
  avatarInitials        String
  obraDescription       String
  obraLocation          String
  lat                   Float?
  lng                   Float?
  obraStart             String?
  obraDuration          String?
  lookingForProfessions String   // JSON: string[]
  contactEmail          String
  contactPhone          String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  contractor User @relation(fields: [contractorId], references: [id])
}

// ── Interest (profissional demonstra interesse em obra/contratante) ───────────

model Interest {
  id                    String   @id @default(cuid())
  contractorId          String   // User.id do contratante
  professionalId        String
  professionalName      String
  professionalInitials  String
  professionalAvatarUrl String?
  profession            String?
  location              String?
  rating                Float?
  createdAt             DateTime @default(now())

  professional User @relation("ProfessionalInterests", fields: [professionalId], references: [id])

  @@unique([contractorId, professionalId])
}

// ── Chat ──────────────────────────────────────────────────────────────────────

model Conversation {
  id                    String   @id  // {userId}_{professionalId}
  userId                String
  professionalId        String
  professionalName      String
  professionalInitials  String
  professionalAvatarUrl String?
  createdAt             DateTime @default(now())

  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  convId     String
  senderId   String
  senderName String
  text       String
  timestamp  DateTime @default(now())

  conversation Conversation @relation(fields: [convId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
}

// ── Notification ──────────────────────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  type           String   // 'log_delete_request' | 'log_deleted' | 'log_edited'
  teamId         String
  teamName       String
  fromMemberId   String
  fromMemberName String
  toMemberId     String
  logId          String?
  logDate        String?
  logHours       Float?
  message        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  toMember   User @relation("ToMember", fields: [toMemberId], references: [id])
  fromMember User @relation("FromMember", fields: [fromMemberId], references: [id])
}
