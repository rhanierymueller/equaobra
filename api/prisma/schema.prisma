generator client {
  provider = "prisma-client-js"
}

// MIGRAÇÃO PARA PRODUÇÃO — quando pronto para deploy:
// 1. Altere provider para "postgresql"
// 2. Atualize DATABASE_URL no .env para a URL do Supabase/Railway/Neon
//    Exemplo: DATABASE_URL="postgresql://user:pass@host:5432/equaobra?schema=public"
// 3. Execute: npx prisma migrate dev --name init
// Obs: SQLite funciona bem para desenvolvimento local e testes

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           String
  roles          String
  profession     String?
  professions    String?
  hourlyRate     Float?
  showHourlyRate Boolean  @default(true)
  avatarUrl      String?
  bio            String?
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  available      Boolean  @default(true)
  phone          String?
  tags           String?
  companyName    String?
  cnpj           String?
  website        String?
  instagram      String?
  facebook       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  addrCep          String?
  addrStreet       String?
  addrNeighborhood String?
  addrCity         String?
  addrState        String?
  addrNumber       String?
  addrLat          Float?
  addrLng          Float?

  compAddrCep          String?
  compAddrStreet       String?
  compAddrNeighborhood String?
  compAddrCity         String?
  compAddrState        String?
  compAddrNumber       String?

  ownedTeams        Team[]         @relation("TeamOwner")
  opportunities     Opportunity[]
  interests         Interest[]     @relation("ProfessionalInterests")
  toNotifications   Notification[] @relation("ToMember")
  fromNotifications Notification[] @relation("FromMember")
  messages          Message[]
}

model Team {
  id             String   @id @default(cuid())
  name           String
  obraLocation   String
  estimatedDays  Int
  observations   String   @default("")
  scheduledStart String
  ownerId        String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner         User           @relation("TeamOwner", fields: [ownerId], references: [id])
  members       TeamMember[]
  workLogs      WorkLog[]
  notifications Notification[]
}

model TeamMember {
  id                String  @id @default(cuid())
  teamId            String
  professionalId    String
  name              String
  profession        String
  phone             String
  avatarUrl         String?
  avatarInitials    String
  hourlyRate        Float?
  isLeader          Boolean @default(false)
  status            String  @default("pending")
  invitationMessage String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model WorkLog {
  id          String   @id @default(cuid())
  teamId      String
  memberId    String
  memberName  String
  date        String
  hours       Float
  description String?
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id                    String   @id @default(cuid())
  contractorId          String
  contractorName        String
  companyName           String?
  avatarInitials        String
  obraDescription       String
  obraLocation          String
  lat                   Float?
  lng                   Float?
  obraStart             String?
  obraDuration          String?
  lookingForProfessions String
  contactEmail          String
  contactPhone          String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  contractor User @relation(fields: [contractorId], references: [id])
}

model Interest {
  id                    String   @id @default(cuid())
  contractorId          String
  professionalId        String
  professionalName      String
  professionalInitials  String
  professionalAvatarUrl String?
  profession            String?
  location              String?
  rating                Float?
  createdAt             DateTime @default(now())

  professional User @relation("ProfessionalInterests", fields: [professionalId], references: [id])

  @@unique([contractorId, professionalId])
}

model Conversation {
  id                    String   @id
  userId                String
  professionalId        String
  professionalName      String
  professionalInitials  String
  professionalAvatarUrl String?
  createdAt             DateTime @default(now())

  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  convId     String
  senderId   String
  senderName String
  text       String
  timestamp  DateTime @default(now())

  conversation Conversation @relation(fields: [convId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
}

model Notification {
  id             String   @id @default(cuid())
  type           String
  teamId         String
  teamName       String
  fromMemberId   String
  fromMemberName String
  toMemberId     String
  logId          String?
  logDate        String?
  logHours       Float?
  message        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  toMember   User @relation("ToMember", fields: [toMemberId], references: [id])
  fromMember User @relation("FromMember", fields: [fromMemberId], references: [id])
}
